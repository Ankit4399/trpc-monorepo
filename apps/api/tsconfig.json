{
  "extends": "@repo/typescript-config/node.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "moduleResolution": "node10",
    // Silence deprecation about node10 moduleResolution in TS6 migration
    "ignoreDeprecations": "6.0",
    "module": "CommonJS",


    // We don't need these for our final build
    "declarationMap": false,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src"],
  "ts-node": {
    "swc": true
  }
}
